---
import Layout from '../layouts/Layout.astro'
import episodes from '../../data/episodes.json'

function formatDuration(seconds: number) {
  const h = Math.floor(seconds / 3600)
  const m = Math.floor((seconds % 3600) / 60)

  return h > 0 ? `${h}h ${m}m` : `${m}m`
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  })
}
---

<Layout>
  <header>
    <div class="header-inner">
      <h1>Epoch's Fables</h1>
      <p class="subtitle">{episodes.length} mixes by <a href="https://www.mixcloud.com/kingstonpork/" target="_blank" rel="noopener noreferrer">kingstonpork</a></p>
    </div>
  </header>

  <main>
    <ul class="grid">
      {episodes.map((ep) => (
        <li class="card">
          <a href={ep.url} target="_blank" rel="noopener noreferrer">
            <div class="cover">
              <img
                src={ep.pictures['320wx320h'] ?? ep.pictures.large}
                alt={ep.name}
                loading="lazy"
                width="320"
                height="320"
              />
            </div>
            <div class="info">
              <span class="name">{ep.name}</span>
              <div class="meta">
                <span>{formatDate(ep.created_time)}</span>
                <span>·</span>
                <span>{formatDuration(ep.audio_length)}</span>
              </div>
              {ep.tags.length > 0 && (
                <ul class="tags">
                  {ep.tags.slice(0, 3).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  header {
    padding: 2rem 1.5rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
  }

  h1 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .subtitle a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }

  .subtitle a:hover {
    text-decoration-color: var(--accent);
  }

  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 6rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    list-style: none;
  }

  .card a {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
    height: 100%;
  }

  .card a:hover {
    border-color: var(--accent);
    background: var(--surface-hover);
    transform: translateY(-3px);
  }

  .cover {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--border);
    flex-shrink: 0;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card a:hover .cover img {
    transform: scale(1.04);
  }

  .info {
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .name {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
  }

  .meta {
    display: flex;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--text-secondary);
    margin-top: auto;
    padding-top: 0.3rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.65rem;
    font-weight: 500;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    letter-spacing: 0.02em;
  }
</style>
