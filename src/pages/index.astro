---
import Layout from '../layouts/Layout.astro'
import episodes from '../../data/episodes.json'

function formatDuration(seconds: number) {
  const h = Math.floor(seconds / 3600)
  const m = Math.floor((seconds % 3600) / 60)

  return h > 0 ? `${h}h ${m}m` : `${m}m`
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  })
}

const tagCounts: Record<string, number> = {}
episodes.forEach((ep) => ep.tags.forEach((t) => { tagCounts[t] = (tagCounts[t] ?? 0) + 1 }))
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 35)
  .map(([tag]) => tag)
  .sort((a, b) => a.localeCompare(b))
---

<Layout>
  <header>
    <div class="header-inner">
      <h1>Epoch's Fables</h1>
      <p class="subtitle">by <a href="https://www.mixcloud.com/kingstonpork/" target="_blank" rel="noopener noreferrer">kingstonpork</a></p>
    </div>
  </header>

  <nav class="filter-bar" aria-label="Filter by tag">
    <div class="filter-inner">
      <button class="filter-btn active" data-tag="">All</button>
      {topTags.map((tag) => (
        <button class="filter-btn" data-tag={tag}>{tag}</button>
      ))}
    </div>
  </nav>

  <main>
    <p class="count" aria-live="polite" aria-atomic="true">
      <span id="count-visible">{episodes.length}</span> of {episodes.length} mixes
    </p>
    <ul class="grid">
      {episodes.map((ep) => (
        <li class="card" data-tags={ep.tags.join('|')}>
          <a href={ep.url} target="_blank" rel="noopener noreferrer">
            <div class="cover">
              <img
                src={ep.pictures['320wx320h'] ?? ep.pictures.large}
                alt={ep.name}
                loading="lazy"
                width="320"
                height="320"
              />
            </div>
            <div class="info">
              <span class="name">{ep.name}</span>
              <div class="meta">
                <span>{formatDate(ep.created_time)}</span>
                <span>·</span>
                <span>{formatDuration(ep.audio_length)}</span>
              </div>
              {ep.tags.length > 0 && (
                <ul class="tags">
                  {ep.tags.slice(0, 3).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
    <p class="no-results" aria-live="polite"></p>
  </main>
</Layout>

<script>
  const TAG_GROUPS: Record<string, string[]> = {
    'Drum & Bass': ['Drum & Bass', 'Liquid Drum & Bass', 'Minimal D&B'],
    'Reggae': ['Reggae', 'Dub Reggae'],
    'Hip Hop': ['Hip Hop', 'Instrumental Hip Hop'],
  }

  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const cards = document.querySelectorAll<HTMLLIElement>('.card')
  const countVisible = document.getElementById('count-visible')!
  const noResults = document.querySelector<HTMLParagraphElement>('.no-results')!

  function filter(tag: string) {
    const matchTags = TAG_GROUPS[tag] ?? (tag ? [tag] : null)
    let visible = 0

    cards.forEach((card) => {
      const cardTags = (card.dataset.tags ?? '').split('|')
      const match = !matchTags || matchTags.some((t) => cardTags.includes(t))
      card.hidden = !match
      if (match) visible++
    })

    countVisible.textContent = String(visible)
    noResults.textContent = visible === 0 ? `No mixes tagged "${tag}"` : ''
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'))
      btn.classList.add('active')
      filter(btn.dataset.tag ?? '')
    })
  })
</script>

<style>
  header {
    padding: 2rem 1.5rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
  }

  h1 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .subtitle a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }

  .subtitle a:hover {
    text-decoration-color: var(--accent);
  }

  .filter-bar {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
    padding: 0.75rem 1.5rem;
  }

  .filter-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .filter-btn {
    flex-shrink: 0;
    font-size: 0.78rem;
    font-weight: 500;
    font-family: inherit;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 6rem;
  }

  .count {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    list-style: none;
  }

  .card a {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
    height: 100%;
  }

  .card a:hover {
    border-color: var(--accent);
    background: var(--surface-hover);
    transform: translateY(-3px);
  }

  .cover {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--border);
    flex-shrink: 0;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card a:hover .cover img {
    transform: scale(1.04);
  }

  .info {
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .name {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
  }

  .meta {
    display: flex;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--text-secondary);
    margin-top: auto;
    padding-top: 0.3rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
  }

  .tags li {
    font-size: 0.65rem;
    font-weight: 500;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    letter-spacing: 0.02em;
  }

  .no-results {
    text-align: center;
    color: var(--text-secondary);
    padding: 4rem 0;
    font-size: 0.95rem;
  }
</style>
