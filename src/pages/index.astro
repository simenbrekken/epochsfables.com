---
import Layout from '../layouts/Layout.astro'
import episodes from '../../data/episodes.json'

function formatDuration(seconds: number) {
  const h = Math.floor(seconds / 3600)
  const m = Math.floor((seconds % 3600) / 60)

  return h > 0 ? `${h}h ${m}m` : `${m}m`
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  })
}
---

<Layout>
  <header>
    <div class="header-inner">
      <h1>Epoch's Fables</h1>
      <p class="subtitle">{episodes.length} mixes by kingstonpork</p>
    </div>
  </header>

  <main>
    <ul class="grid">
      {episodes.map((ep) => (
        <li class="card">
          <a href={ep.url} target="_blank" rel="noopener noreferrer">
            <div class="cover">
              <img
                src={ep.pictures['320wx320h'] ?? ep.pictures.large}
                alt={ep.name}
                loading="lazy"
                width="320"
                height="320"
              />
            </div>
            <div class="info">
              <span class="name">{ep.name}</span>
              <div class="meta">
                <span>{formatDate(ep.created_time)}</span>
                <span>·</span>
                <span>{formatDuration(ep.audio_length)}</span>
              </div>
              {ep.tags.length > 0 && (
                <ul class="tags">
                  {ep.tags.slice(0, 3).map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  header {
    padding: 3rem 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--accent);
  }

  .subtitle {
    margin-top: 0.4rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    list-style: none;
  }

  .card a {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s, transform 0.15s;
  }

  .card a:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .cover {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--border);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .name {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .meta {
    display: flex;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    margin-top: 0.1rem;
  }

  .tags li {
    font-size: 0.7rem;
    background: var(--border);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
    color: var(--muted);
  }
</style>
