---
interface Props {
  title?: string
}

const { title = "Epoch's Fables" } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The complete archive of Epoch's Fables — a long-running mix series by kingstonpork." />
    <title>{title}</title>
    <script src="//widget.mixcloud.com/media/js/widgetApi.js" is:inline></script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0a0a0a;
        --surface: #141414;
        --surface-hover: #1c1c1c;
        --border: #242424;
        --text: #f0f0f0;
        --text-secondary: #a0a0a0;
        --muted: #666;
        --accent: #b8914a;
        --accent-dim: rgba(184, 145, 74, 0.12);
        --radius: 8px;
        --font: system-ui, -apple-system, 'Segoe UI', sans-serif;
      }

      @media (prefers-color-scheme: light) {
        :root {
          --bg: #f5f5f0;
          --surface: #ffffff;
          --surface-hover: #f0ede8;
          --border: #e0ddd8;
          --text: #1a1a1a;
          --text-secondary: #666;
          --muted: #999;
          --accent: #8b6914;
          --accent-dim: rgba(139, 105, 20, 0.1);
        }
      }

      html {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        -webkit-font-smoothing: antialiased;
      }

      body { min-height: 100vh; }

      a { color: inherit; text-decoration: none; }

      img { display: block; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
